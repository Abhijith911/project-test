import cv2
import pytesseract
import re
import pandas as pd
from datetime import datetime
import os

# ================= Excel Setup =================
file_name = "parking_data.xlsx"

if not os.path.exists(file_name):
    current_df = pd.DataFrame(columns=["Vehicle Number", "Entry Time"])
    history_df = pd.DataFrame(columns=["Vehicle Number", "Entry Time", "Exit Time"])

    with pd.ExcelWriter(file_name, engine="openpyxl") as writer:
        current_df.to_excel(writer, sheet_name="CURRENT_VEHICLES", index=False)
        history_df.to_excel(writer, sheet_name="HISTORY_LOG", index=False)

    print("✅ Excel file created")

# ================= Entry / Exit Functions =================
def vehicle_entry(vehicle_number):
    current_df = pd.read_excel(file_name, sheet_name="CURRENT_VEHICLES")
    history_df = pd.read_excel(file_name, sheet_name="HISTORY_LOG")

    if vehicle_number in current_df["Vehicle Number"].values:
        print("⚠ Vehicle already inside")
        return

    entry_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    current_df.loc[len(current_df)] = [vehicle_number, entry_time]
    history_df.loc[len(history_df)] = [vehicle_number, entry_time, ""]

    with pd.ExcelWriter(file_name, engine="openpyxl", mode="a", if_sheet_exists="replace") as writer:
        current_df.to_excel(writer, sheet_name="CURRENT_VEHICLES", index=False)
        history_df.to_excel(writer, sheet_name="HISTORY_LOG", index=False)

    print(f"🟢 ENTRY stored for {vehicle_number}")

def vehicle_exit(vehicle_number):
    current_df = pd.read_excel(file_name, sheet_name="CURRENT_VEHICLES")
    history_df = pd.read_excel(file_name, sheet_name="HISTORY_LOG")

    if vehicle_number not in current_df["Vehicle Number"].values:
        print("⚠ Vehicle not found inside")
        return

    exit_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    current_df = current_df[current_df["Vehicle Number"] != vehicle_number]

    history_df.loc[
        (history_df["Vehicle Number"] == vehicle_number) &
        (history_df["Exit Time"] == ""),
        "Exit Time"
    ] = exit_time

    with pd.ExcelWriter(file_name, engine="openpyxl", mode="a", if_sheet_exists="replace") as writer:
        current_df.to_excel(writer, sheet_name="CURRENT_VEHICLES", index=False)
        history_df.to_excel(writer, sheet_name="HISTORY_LOG", index=False)

    print(f"🔴 EXIT stored for {vehicle_number}")

# ================= Camera + OCR =================
cap = cv2.VideoCapture(0, cv2.CAP_DSHOW)

print("Press 'c' to capture plate | 'q' to quit")

while True:
    ret, frame = cap.read()
    if not ret:
        break

    cv2.imshow("Live Camera", frame)
    key = cv2.waitKey(1) & 0xFF

    if key == ord('c'):
        # 1️⃣ Grayscale
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        # 2️⃣ Noise reduction
        gray = cv2.bilateralFilter(gray, 11, 17, 17)

        # 3️⃣ Edge detection
        edges = cv2.Canny(gray, 30, 200)

        # 4️⃣ Find contours
        contours, _ = cv2.findContours(edges, cv2.RETR_TREE, cv2.CHAIN_APPROX_SIMPLE)
        contours = sorted(contours, key=cv2.contourArea, reverse=True)[:10]

        plate = None
        for cnt in contours:
            peri = cv2.arcLength(cnt, True)
            approx = cv2.approxPolyDP(cnt, 0.018 * peri, True)
            if len(approx) == 4:
                plate = approx
                break

        if plate is None:
            print("❌ No plate detected")
            continue

        # 5️⃣ Crop plate
        x, y, w, h = cv2.boundingRect(plate)
        plate_img = gray[y:y+h, x:x+w]

        # 6️⃣ OCR preprocessing
        plate_img = cv2.resize(plate_img, None, fx=2, fy=2, interpolation=cv2.INTER_CUBIC)
        plate_img = cv2.GaussianBlur(plate_img, (3, 3), 0)
        plate_img = cv2.threshold(plate_img, 150, 255, cv2.THRESH_BINARY)[1]

        cv2.imshow("Detected Plate", plate_img)

        # 7️⃣ OCR
        config = r'--oem 3 --psm 6 -c tessedit_char_whitelist=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'
        text = pytesseract.image_to_string(plate_img, config=config)

        print("\nRaw OCR Output:", repr(text))

        # 8️⃣ Clean OCR output
        candidate = re.sub(r'[^A-Z0-9]', '', text.upper())
        print("After Cleaning:", candidate)

        # 9️⃣ Regex validation
        pattern = r'[A-Z]{2}[0-9]{2}[A-Z]{1,2}[0-9]{3,4}'
        match = re.search(pattern, candidate)

        if match:
            vehicle_number = match.group()
            print("✅ Detected Vehicle Number:", vehicle_number)

            # 🔑 ENTRY / EXIT LOGIC
            current_df = pd.read_excel(file_name, sheet_name="CURRENT_VEHICLES")

            if vehicle_number in current_df["Vehicle Number"].values:
                print("🚗 EXIT detected")
                vehicle_exit(vehicle_number)
            else:
                print("🚗 ENTRY detected")
                vehicle_entry(vehicle_number)
        else:
            print("❌ No valid plate found")

    elif key == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()
